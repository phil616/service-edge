# Binaries
/bin/
*.exe
*.test
/service-edge
/agent

# Data / runtime
*.db
*.db-journal
*.db-wal
*.db-shm
/data/
*.log

# Local dev secrets / certs
/dev/
*.crt
*.key
*.pem
!web/**/*.key

# Config (keep example only)
config.yaml
config.local.yaml

# Frontend
web/node_modules/
web/dist/
web/.vite/

# Embedded frontend build output (regenerated by `make web`).
# Keep .gitkeep so `//go:embed all:dist` still compiles on a fresh clone.
internal/web/dist/*
!internal/web/dist/.gitkeep

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
